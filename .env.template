# nginx-proxy / acme-companion: set VIRTUAL_HOST to the hostname(s) you serve. LETSENCRYPT_HOST should
# match when requesting certs. Leave LETSENCRYPT_EMAIL empty if userver-web letsencrypt/.env sets
# DEFAULT_EMAIL once—repeating the same email on every container breaks ACME (invalidContact).
VIRTUAL_HOST=
LETSENCRYPT_HOST=
LETSENCRYPT_EMAIL=

POSTGRES_HOST=
POSTGRES_DB=
POSTGRES_DB_TEST=
POSTGRES_USER=
# Applied on every setup (non --reset): existing roles are ALTERed so the DB password matches.
POSTGRES_PASS=
POSTGRES_PORT=5432

ENV_MODE=prod
# HTTP listen port (Render/Heroku-style PORT is also read if APP_PORT is unset)
APP_PORT=5000

# Optional: bcrypt cost (defaults: 13 when ENV_MODE=prod, else 4)
# BCRYPT_COST=13

# HMAC secret for JWT signing (required)
APP_SECRET_KEY=

SYSTEM_CREATION_TOKEN=

JWT_EXP_DELTA_SECS=3600
JWT_REFRESH_DELTA_SECS=259200

# For setup only
POSTGRES_ROOT_USER=
POSTGRES_ROOT_PASS=

# Set to 1 to skip ./setup.sh on container start. Use when Postgres is down or migrations run elsewhere.
SKIP_DB_SETUP=0

# Binary paths for setup (migrate) and the API. Release image default is /app/main (see Dockerfile).
# Docker Compose bind-mount dev (after `make go-build`): uncomment and point at the Linux binary:
# MIGRATE_BIN=./out/userver-auth
# APP_BIN=./out/userver-auth

# Optional: HTTP throttling (ulule/limiter formatted rates; comma-separate multiple tiers for globals).
# See https://github.com/ulule/limiter — suffixes: S second, M minute, H hour, D day.
# RATELIMIT_GLOBAL_PROD=1000-D
# RATELIMIT_GLOBAL_DEV=10000-D,100-H
# RATELIMIT_AUTH_SYSTEM=100-D
# RATELIMIT_AUTH_BURST=1000-H
# RATELIMIT_AUTH_READ=10000-H
# Optional: shared store for limiter (reserved for future use)
# RATELIMIT_STORAGE_URI=

# Optional Sentry
# SENTRY_DSN=
